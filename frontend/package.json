    "@tauri-apps/plugin-updater": "^2",
    "katex": "^0.16.38",
    "lucide-react": "^0.576.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.13.1",
